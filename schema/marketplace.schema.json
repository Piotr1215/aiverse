{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "aiverse marketplace.json",
  "type": "object",
  "required": ["name", "owner", "plugins"],
  "additionalProperties": false,
  "properties": {
    "name": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "owner": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      },
      "additionalProperties": false
    },
    "metadata": {
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "version": { "type": "string" },
        "homepage": { "type": "string", "format": "uri" },
        "keywords": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "plugins": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/plugin" }
    }
  },
  "definitions": {
    "plugin": {
      "type": "object",
      "required": ["name", "source", "description"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "description": { "type": "string", "minLength": 1 },
        "version": { "type": "string" },
        "author": {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string" }
          }
        },
        "category": { "type": "string" },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "strict": { "type": "boolean" },
        "source": {
          "oneOf": [
            { "$ref": "#/definitions/relativePathSource" },
            { "$ref": "#/definitions/githubSource" }
          ]
        },
        "lspServers": { "type": "object" },
        "mcpServers": { "type": "object" },
        "hooks": { "type": ["object", "string"] },
        "commands": { "type": ["array", "string"] },
        "agents": { "type": ["array", "string"] },
        "skills": { "type": ["array", "string"] }
      },
      "additionalProperties": false
    },
    "relativePathSource": {
      "type": "string",
      "pattern": "^\\./"
    },
    "githubSource": {
      "type": "object",
      "required": ["source", "repo"],
      "properties": {
        "source": { "const": "github" },
        "repo": { "type": "string", "pattern": "^[^/]+/[^/]+$" },
        "branch": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
